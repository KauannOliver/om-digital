### caminho base da aplicação na url ###
VITE_BASE_PATH=/mnt/disponibilidade/

### tempo limite para requisições http (milissegundos) ###
VITE_HTTP_TIMEOUT_MS=60000

### tempo de cache para dados da home (milissegundos, padrão 24h) ###
VITE_HOME_CACHE_MS=86400000

### estratégia de cache http padrão (ex: no-store, force-cache) ###
VITE_HTTP_CACHE=no-store

### endereço do servidor backend para o proxy do vite ###
VITE_API_PROXY_TARGET=http://localhost:3001

### prefixo base para chamadas de api (opcional) ###
VITE_API_BASE=

### intervalo de sincronização global das ordens (milissegundos, padrão 2 min) ###
VITE_GLOBAL_SYNC_MS=120000

### intervalo de atualização dos resumos no painel lateral (milissegundos, padrão 1 min) ###
VITE_SIDEPANEL_SYNC_MS=60000

### tempo de inatividade para alternar para tela de comunicados (milissegundos, padrão 10 min) ###
VITE_IDLE_TIMEOUT_MS=600000

### porta em que o servidor backend irá rodar ###
PORT=3001

### tempo de vida (ttl) do cache geral no servidor (milissegundos) ###
CACHE_TTL_MS=60000

### ttl do cache para dados da home no servidor (milissegundos) ###
HOME_CACHE_TTL_MS=86400000

### ttl do cache para a lista completa de ordens (milissegundos) ###
ORDERS_CACHE_TTL_MS=60000

### ttl do cache para resumos de disponibilidade (milissegundos) ###
ASSETS_CACHE_TTL_MS=60000

### endereço do banco de dados mysql (azure) ###
DB_HOST=db-host.sql.com

### nome do schema do banco de dados ###
DB_NAME=db-name

### usuário de acesso ao banco ###
DB_USER=usuario

### senha do usuário do banco ###
DB_PASSWORD=senha_exemplo

### porta de conexão do mysql ###
DB_PORT=3306

### se deve utilizar conexão segura ssl com o banco (azure requer true) ###
DB_SSL=true
